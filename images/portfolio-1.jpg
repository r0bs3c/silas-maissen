<?xml version="1.0" encoding="UTF-8"?>
<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
      <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#b8956a" stroke-width="0.5" opacity="0.3"/>
    </pattern>
  </defs>
  <rect width="400" height="300" fill="#2d4a3e"/>
  <rect width="400" height="300" fill="url(#grid)"/>
  <rect x="50" y="50" width="300" height="200" fill="none" stroke="#d4c5b9" stroke-width="3" stroke-dasharray="10,5"/>
  <text x="200" y="140" font-family="Arial, sans-serif" font-size="20" fill="#d4c5b9" text-anchor="middle" font-weight="bold">
    Portfolio-Bild 1
  </text>
  <text x="200" y="165" font-family="Arial, sans-serif" font-size="12" fill="#d4c5b9" text-anchor="middle">
    Terrassengeländer
  </text>
  <text x="200" y="250" font-family="Arial, sans-serif" font-size="10" fill="#d4c5b9" text-anchor="middle" opacity="0.8">
    Ersetzen Sie dieses Bild mit: images/portfolio-1.jpg
  </text>
</svg>