<?xml version="1.0" encoding="UTF-8"?>
<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <pattern id="metal" patternUnits="userSpaceOnUse" width="20" height="20">
      <rect width="20" height="20" fill="#4a5568"/>
      <line x1="0" y1="0" x2="20" y2="0" stroke="#b8956a" stroke-width="1" opacity="0.5"/>
      <line x1="0" y1="10" x2="20" y2="10" stroke="#b8956a" stroke-width="1" opacity="0.3"/>
    </pattern>
  </defs>
  <rect width="400" height="300" fill="url(#metal)"/>
  <rect x="50" y="40" width="300" height="200" fill="none" stroke="#d4c5b9" stroke-width="4"/>
  <rect x="100" y="80" width="100" height="120" fill="#4a5568" opacity="0.3"/>
  <rect x="200" y="100" width="100" height="100" fill="#2d4a3e" opacity="0.3"/>
  <text x="200" y="140" font-family="Arial, sans-serif" font-size="20" fill="#d4c5b9" text-anchor="middle" font-weight="bold">
    Portfolio-Bild 6
  </text>
  <text x="200" y="165" font-family="Arial, sans-serif" font-size="12" fill="#d4c5b9" text-anchor="middle">
    Stahlkonstruktion
  </text>
  <text x="200" y="250" font-family="Arial, sans-serif" font-size="10" fill="#d4c5b9" text-anchor="middle" opacity="0.8">
    Ersetzen Sie dieses Bild mit: images/portfolio-6.jpg
  </text>
</svg>